# Sanad Waitlist API — standalone pre-launch service
# Deploys on Railway — root of this repo, railway.json drives build/start.
PORT=3005
NODE_ENV=production

# Same Supabase project + database as the main platform
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."
SUPABASE_URL="https://[project].supabase.co"
SUPABASE_ANON_KEY="eyJ..."

# Confirmation email (Resend preferred; SMTP is the fallback)
RESEND_API_KEY=""
RESEND_FROM="Sanad Platform <no-reply@sanadabujaber.blog>"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Swagger is off in production unless this is set
# ENABLE_SWAGGER=true
